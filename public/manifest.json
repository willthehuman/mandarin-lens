{
  "manifest_version": 3,
  "name": "Mandarin Lens",
  "description": "Analyze selected English or Mandarin text, plus right-clicked images, with Mandarin, pinyin, and learning notes.",
  "version": "1.0.2",
  "minimum_chrome_version": "116",
  "permissions": ["contextMenus", "sidePanel", "storage", "identity"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://openrouter.ai/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Mandarin Lens",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
